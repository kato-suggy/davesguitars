{
  "name": "davesguitars",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n wrangler,css -c yellow,cyan \"wrangler dev\" \"npm run dev:css\"",
    "dev:css": "tailwindcss -i ./src/styles/main.css -o ./public/styles.css --watch",
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/styles.css --minify",
    "build": "npm run build:css && wrangler deploy --dry-run",
    "deploy": "npm run build:css && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "marked": "^12.0.0",
    "dompurify": "^3.1.0",
    "jsdom": "^24.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.0",
    "wrangler": "^3.78.0"
  }
}
